generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile   Profile?
  tasks     Task[]

  @@map("users")
}

model Profile {
  id            Int       @id @default(autoincrement())
  userId        Int       @unique @map("user_id")
  name          String
  childGender   Gender?   @map("child_gender")
  dueDate       DateTime? @map("due_date")
  avatarUrl     String?   @map("avatar_url")
  avatarPublicId String?  @map("avatar_public_id") 
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

model Task {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  date      DateTime
  isDone    Boolean  @default(false) @map("is_done")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("tasks")
}

model BabyState {
  id               Int      @id @default(autoincrement())
  sourceId         String   @unique @map("source_id")
  weekNumber       Int      @unique @map("week_number")
  analogy          String?
  babySize         Float    @map("baby_size")
  babyWeight       Float    @map("baby_weight")
  image            String
  babyActivity     String   @map("baby_activity")
  babyDevelopment  String   @map("baby_development")
  interestingFact  String   @map("interesting_fact")
  momDailyTips     Json     @map("mom_daily_tips")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("baby_states")
}

model MomState {
  id          Int      @id @default(autoincrement())
  sourceId    String   @unique @map("source_id")
  weekNumber  Int      @unique @map("week_number")
  feelings    Json
  comfortTips Json     @map("comfort_tips")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("mom_states")
}

model Emotion {
  id        Int      @id @default(autoincrement())
  sourceId  String   @unique @map("source_id")
  title     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("emotions")
}
